pragma solidity ^0.8.20;

import "erc721a/contracts/ERC721A.sol";

import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/token/common/ERC2981.sol";
import "@openzeppelin/contracts/utils/Pausable.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";

contract TheBullBrewCollection is
    ERC721A,
    Ownable,
    ERC2981,
    Pausable,
    ReentrancyGuard
{
    uint256 public constant MAX_SUPPLY = 1000;

    uint256 public mintPrice = 0.002 ether;

    uint256 public maxPerWallet = 5;

    bool public revealed = false;

    bool public metadataFrozen = false;

    string public hiddenURI;

    string private baseTokenURI;

    string public provenanceHash;

    mapping(address => uint256) public minted;

    constructor(
        string memory _hiddenURI,
        address royaltyReceiver,
        string memory _provenanceHash
    )
        ERC721A(
            "THEBULLBREWCOLLECTION",
            "BRW"
        )
        Ownable(msg.sender)
    {
        hiddenURI = _hiddenURI;

        provenanceHash = _provenanceHash;

        _setDefaultRoyalty(
            royaltyReceiver,
            750
        );
    }

    function mint(
        uint256 quantity
    )
        external
        payable
        whenNotPaused
        nonReentrant
    {
        require(
            quantity > 0,
            "Invalid quantity"
        );

        require(
            totalSupply() + quantity
                <= MAX_SUPPLY,
            "Sold out"
        );

        require(
            minted[msg.sender]
                + quantity
                <= maxPerWallet,
            "Wallet limit exceeded"
        );

        require(
            msg.value
                >= mintPrice * quantity,
            "Insufficient payment"
        );

        minted[msg.sender] += quantity;

        _safeMint(
            msg.sender,
            quantity
        );
    }

    function isMember(
        address wallet
    )
        external
        view
        returns (bool)
    {
        return balanceOf(wallet) > 0;
    }

    function revealCollection(
        string calldata newBaseURI
    )
        external
        onlyOwner
    {
        require(
            !metadataFrozen,
            "Metadata frozen"
        );

        revealed = true;

        baseTokenURI = newBaseURI;
    }

    function freezeMetadata()
        external
        onlyOwner
    {
        metadataFrozen = true;
    }

    function setMintPrice(
        uint256 newPrice
    )
        external
        onlyOwner
    {
        mintPrice = newPrice;
    }

    function setMaxPerWallet(
        uint256 newLimit
    )
        external
        onlyOwner
    {
        maxPerWallet = newLimit;
    }

    function pause()
        external
        onlyOwner
    {
        _pause();
    }

    function unpause()
        external
        onlyOwner
    {
        _unpause();
    }

    function withdraw()
        external
        onlyOwner
        nonReentrant
    {
        (bool success,) =
            payable(owner()).call{
                value: address(this).balance
            }("");

        require(
            success,
            "Withdrawal failed"
        );
    }

    function _baseURI()
        internal
        view
        override
        returns (string memory)
    {
        return baseTokenURI;
    }

    function tokenURI(
        uint256 tokenId
    )
        public
        view
        override
        returns (string memory)
    {
        require(
            _exists(tokenId),
            "Token does not exist"
        );

        if (!revealed) {
            return hiddenURI;
        }

        return super.tokenURI(
            tokenId
        );
    }

    function supportsInterface(
        bytes4 interfaceId
    )
        public
        view
        override(
            ERC721A,
            ERC2981
        )
        returns (bool)
    {
        return
            ERC721A.supportsInterface(
                interfaceId
            ) ||
            ERC2981.supportsInterface(
                interfaceId
            );
    }
}


// Hardhat Deploy Script


const hre = require("hardhat");

async function main() {

  const Contract =
    await hre.ethers.getContractFactory(
      "TheBullBrewCollection"
    );

  const nft =
    await Contract.deploy(
      "ipfs://HIDDEN_METADATA_CID/hidden.json",
      "YOUR_WALLET_ADDRESS",
      "YOUR_SHA256_PROVENANCE_HASH"
    );

  await nft.waitForDeployment();

  console.log(
    "Contract deployed:",
    await nft.getAddress()
  );
}

main().catch((error) => {
  console.error(error);
  process.exitCode = 1;
});


